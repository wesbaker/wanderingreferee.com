---
interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
---

<header class="site-header">
  <a href="/" class="site-title">Wandering <span>Referee</span></a>
  <nav class="site-nav" aria-label="Primary navigation">
    <a href="/about" aria-current={currentPath === '/about' ? 'page' : undefined}>About</a>
    <button class="search-trigger" type="button" aria-label="Search" onclick="window.openSearch?.()">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
      <kbd>&#8984;K</kbd>
    </button>
  </nav>
</header>
