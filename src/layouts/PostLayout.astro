---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { MarkdownHeading } from 'astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { formatPostDate, getAllTags } from '../lib/content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  date: Date;
  tags?: string[];
  draft?: boolean;
  image?: ImageMetadata;
  headings: MarkdownHeading[];
  isLink?: boolean;
  externalUrl?: string;
}

const {
  title,
  subtitle,
  description,
  date,
  tags = [],
  draft = false,
  image,
  headings,
  isLink = false,
  externalUrl,
} = Astro.props;
const formattedDate = formatPostDate(date);
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site).toString();
const sidebarTags = await getAllTags();
let ogImage: string | undefined;
if (image) {
  const processed = await getImage({ src: image, width: 1200, format: 'jpeg' });
  ogImage = processed.src;
}
---

<BaseLayout title={title} description={description} image={ogImage} canonicalUrl={canonicalUrl} type="article">
  <Header currentPath={currentPath} />

  <div class="layout">
    <main>
      <div class="post-meta">
        <span>{formattedDate}</span>
        {draft && <span class="tag-draft">Draft</span>}
        {
          tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">
              {tag}
            </a>
          ))
        }
      </div>

      {(() => {
        const heading = (
          <h1 class="post-heading">
            {isLink && externalUrl
              ? <a href={externalUrl} rel="noopener noreferrer">{title}</a>
              : title
            }
          </h1>
        );
        return subtitle ? (
          <hgroup>
            {heading}
            <p class="post-subtitle">{subtitle}</p>
          </hgroup>
        ) : heading;
      })()}

      {
        image && (
          <div class="post-feature">
            <Image src={image} alt="" loading="lazy" />
          </div>
        )
      }

      <div class="post-body">
        <slot />
      </div>
    </main>

    <Sidebar headings={headings} tags={sidebarTags} showAbout={true} showSocial={true} socialLabel="About" />
  </div>

  <Footer />
</BaseLayout>
