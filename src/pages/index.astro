---
import { getCollection } from 'astro:content';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Pagination from '../components/Pagination.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getAllTags } from '../lib/content';
import { mergeFeed, type FeedItem } from '../lib/feed';
import { homeIntro, pageSize } from '../lib/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const feed = mergeFeed<FeedItem>(
  posts.map((entry) => ({ type: 'post' as const, entry, date: entry.data.date })),
);
const tags = await getAllTags();
const pageData = feed.slice(0, pageSize);
const lastPage = Math.ceil(feed.length / pageSize);
---

<BaseLayout title="Wandering Referee">
  <Header currentPath="/" />

  <div class="layout">
    <main class="feed">
      {
        pageData.map((item) => <PostCard post={item.entry} />)
      }

      <Pagination currentPage={1} lastPage={lastPage} />
    </main>

    <Sidebar tags={tags} showAbout={true} aboutText={homeIntro} showSocial={true} />
  </div>

  <Footer />
</BaseLayout>
